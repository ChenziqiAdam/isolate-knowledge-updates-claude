\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Main results comparing editing methods. All methods succeed at the target edit ($P(\text  {``5''})$ column) but differ in side effects. \textsc  {Rome}\xspace  best preserves perplexity while \textsc  {LoRA}\xspace  achieves the highest target probability but causes the most general degradation. Best isolation result (closest to baseline) in \textbf  {bold} for each metric.\relax }}{5}{table.caption.4}\protected@file@percent }
\newlabel{tab:main}{{3}{5}{Main results comparing editing methods. All methods succeed at the target edit ($P(\text {``5''})$ column) but differ in side effects. \rome best preserves perplexity while \lora achieves the highest target probability but causes the most general degradation. Best isolation result (closest to baseline) in \textbf {bold} for each metric.\relax }{table.caption.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Per-query outputs for related arithmetic. \textbf  {BROKEN} = was correct at baseline but incorrect after editing. \textbf  {FIXED} = was incorrect at baseline but correct after editing. The dominant pattern is a universal shift to ``5'' across all methods.\relax }}{5}{table.caption.5}\protected@file@percent }
\newlabel{tab:per_query}{{4}{5}{Per-query outputs for related arithmetic. \textbf {BROKEN} = was correct at baseline but incorrect after editing. \textbf {FIXED} = was incorrect at baseline but correct after editing. The dominant pattern is a universal shift to ``5'' across all methods.\relax }{table.caption.5}{}}
